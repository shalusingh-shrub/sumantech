# Laravel 12 .gitignore

# Dependencies

/vendor/
/node_modules/

# Bootstrap cache

/bootstrap/cache/

# Environment files

.env
.env.*
!.env.example

# Application key & secrets

/storage/*.key

# Laravel storage (keep structure, ignore contents)

/storage/*
!/storage/app/
/storage/app/*
!/storage/app/.gitignore
/storage/app/public/*
!/storage/app/public/.gitignore
/storage/framework/*
!/storage/framework/cache/
/storage/framework/cache/*
!/storage/framework/cache/data/
/storage/framework/cache/data/.gitignore
!/storage/framework/sessions/
/storage/framework/sessions/.gitignore
!/storage/framework/views/
/storage/framework/views/.gitignore
/storage/logs/*
!/storage/logs/.gitignore

# Public storage symlink

/public/storage
 
# Build / frontend

/public/build
/public/hot

# Logs

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cache

.phpunit.result.cache

# OS / Editor

.DS_Store
Thumbs.db

# IDEs

/.vscode/
/.idea/
/.phpactor.json

# Vagrant

/.vagrant

# Homestead

Homestead.yaml
Homestead.json

# Misc

auth.json
